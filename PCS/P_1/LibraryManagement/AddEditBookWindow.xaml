<Window x:Class="LibraryManagement.AddEditBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Добавить книгу"
        Width="400" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Название:" Margin="0,0,0,4" />
        <TextBox x:Name="TitleBox" Grid.Row="1" Margin="0,0,0,12" Padding="4,2" />

        <TextBlock Grid.Row="2" Text="Автор:" Margin="0,0,0,4" />
        <ComboBox x:Name="AuthorCombo" Grid.Row="3" Margin="0,0,0,12" Padding="4,2"
                  DisplayMemberPath="FullName" />

        <TextBlock Grid.Row="4" Text="Жанр:" Margin="0,0,0,4" />
        <ComboBox x:Name="GenreCombo" Grid.Row="5" Margin="0,0,0,12" Padding="4,2"
                  DisplayMemberPath="Name" />

        <TextBlock Grid.Row="6" Text="Год издания:" Margin="0,0,0,4" />
        <TextBox x:Name="PublishYearBox" Grid.Row="7" Margin="0,0,0,12" Padding="4,2" />

        <TextBlock Grid.Row="8" Text="ISBN:" Margin="0,0,0,4" />
        <TextBox x:Name="IsbnBox" Grid.Row="9" Margin="0,0,0,12" Padding="4,2" />

        <TextBlock Grid.Row="10" Text="Количество в наличии:" Margin="0,0,0,4" />
        <TextBox x:Name="QuantityBox" Grid.Row="11" Margin="0,0,0,16" Padding="4,2" />

        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="SaveButton" Content="Сохранить" Click="SaveButton_Click" IsDefault="True" Padding="16,6" Margin="0,0,8,0" />
            <Button Content="Отмена" IsCancel="True" Click="CancelButton_Click" Padding="16,6" />
        </StackPanel>
    </Grid>
</Window>
