<Window x:Class="NetworkAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Анализатор сетевых подключений"
        Height="620" Width="900"
        MinHeight="500" MinWidth="750">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Сетевые интерфейсы" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>

        <!-- Верхняя часть: список интерфейсов + детали -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ListBox x:Name="InterfacesListBox"
                         Grid.Row="0"
                         DisplayMemberPath="Name"
                         SelectionChanged="InterfacesListBox_SelectionChanged"
                         Margin="0,0,0,6"
                         BorderThickness="1" BorderBrush="#CCC"/>

                <TextBlock Grid.Row="1"
                           Text="Информация о выбранном интерфейсе"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

                <Border Grid.Row="2"
                        BorderBrush="#CCC"
                        BorderThickness="1"
                        Padding="8"
                        Background="#FAFAFA">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="InterfaceDetailsText"
                                   TextWrapping="Wrap"
                                   FontFamily="Consolas"
                                   FontSize="12"/>
                    </ScrollViewer>
                </Border>
            </Grid>

            <StackPanel Grid.Column="1" Margin="20,0,0,0">
                <TextBlock Text="Проверка и анализ URL/URI" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="UrlTextBox"
                             Grid.Column="0"
                             Padding="6,4"
                             FontSize="13"
                             VerticalContentAlignment="Center"
                             KeyDown="UrlTextBox_KeyDown"/>
                    <Button x:Name="AnalyzeUrlButton"
                            Grid.Column="1"
                            Content="Анализировать"
                            Margin="8,0,0,0"
                            Padding="12,6"
                            Click="AnalyzeUrlButton_Click"/>
                </Grid>
                <TextBlock Text="Результаты анализа" FontWeight="SemiBold" Margin="0,12,0,4"/>
                <Border BorderBrush="#CCC" BorderThickness="1" Padding="10" Background="#FAFAFA">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="UrlResultsPanel">
                            <TextBlock x:Name="UrlResultsText" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </Grid>

        <Separator Grid.Row="2" Margin="0,4"/>

        <!-- История URL -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Text="История проверенных URL"
                       FontWeight="Bold"
                       FontSize="14"
                       Margin="0,0,0,6"/>
            <ListBox x:Name="UrlHistoryListBox"
                     Grid.Row="1"
                     SelectionChanged="UrlHistoryListBox_SelectionChanged"
                     MinHeight="80"
                     BorderThickness="1"
                     BorderBrush="#CCC"/>
        </Grid>
    </Grid>
</Window>
